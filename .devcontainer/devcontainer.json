{
	"name": "synth-setter",
	"image": "tinaudio/perm:dev-live",
	"workspaceMount": "source=${localWorkspaceFolder},target=/home/build/synth-setter,type=bind,consistency=cached",
	"workspaceFolder": "/home/build/synth-setter",
	"postCreateCommand": "pip install --no-deps -e .",
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance"
			]
		}
	}
}

# =============================================================================
# .env.cloud.example — Worker-side environment for SkyPilot launches
# =============================================================================
# Copy to .env.cloud and fill in real values. Never commit .env.cloud.
# Loaded by scripts/skypilot_launch_smoke.py and forwarded verbatim to the
# worker via task.update_envs(...).
#
# Minimum required for `generate_dataset` (rclone uploads to R2). The launcher
# does not enforce a fixed key set — add additional vars here as future stages
# need them (e.g. WANDB_API_KEY for training).

RCLONE_CONFIG_R2_TYPE=s3
RCLONE_CONFIG_R2_PROVIDER=Cloudflare
RCLONE_CONFIG_R2_ACCESS_KEY_ID=your-r2-access-key-id
RCLONE_CONFIG_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
RCLONE_CONFIG_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

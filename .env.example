# =============================================================================
# .env.example — Environment variables for synth-setter
# =============================================================================
# Copy to .env and fill in your values. Never commit .env (it's in .gitignore).
# Hydra configs can reference these via: ${oc.env:VAR_NAME}
#
# To export all vars into your current shell:
#   set -a && source .env; set +a
#
# Write values BARE — KEY=value, never KEY="value". Docker `--env-file`
# (devcontainers + `docker run --env-file .env` per docs/reference/docker.md)
# passes quotes through literally; shell `source` and python-dotenv strip
# them, which masks the bug — see #1282.

# =============================================================================
# Cloudflare R2 (S3-compatible object storage)
# =============================================================================
# Used by: Docker builds (BuildKit secrets), rclone, pipeline entrypoints

# Rclone-style R2 env vars — read directly by rclone (no rclone.conf needed)
# and forwarded to workers by the SkyPilot launcher. Get the access key and
# secret from Cloudflare R2 dashboard → Manage R2 API Tokens; the endpoint is
# account-specific.
RCLONE_CONFIG_R2_TYPE=s3
RCLONE_CONFIG_R2_PROVIDER=Cloudflare
RCLONE_CONFIG_R2_ACCESS_KEY_ID=your-r2-access-key-id
RCLONE_CONFIG_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
RCLONE_CONFIG_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Cloudflare account ID (the subdomain prefix of the R2 endpoint above).
# Required by `scripts/skypilot_write_provider_creds.sh` to write
# `~/.cloudflare/accountid` for SkyPilot's R2 storage adaptor (#749). The
# launcher invokes that bootstrap by default.
R2_ACCOUNT_ID=your-cloudflare-account-id

# R2 bucket name — only consumed outside Docker (e.g. ad-hoc rclone
# commands). Inside the container, generate_dataset reads the bucket from
# the DatasetSpec, so this env var is NOT required at runtime.
R2_BUCKET=intermediate-data

# Optional env var to use a remote SkyPilot API server.
# See docs/operations/skypilot-remote-server-playbook.md for how to set up
# a remote server.
SKYPILOT_API_SERVER_ENDPOINT=https://skypilot:YOUR_PASSWORD@YOUR_SKYPILOT_HOSTNAME

# Required for W&B to resolve R2 artifact references via S3 protocol
# (without this, W&B attempts to resolve against AWS S3)
WANDB_S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# Generic AWS S3 protocol → R2 redirect, for tools that do NOT read the
# RCLONE_CONFIG_R2_* vars above: the SmooSense / DuckDB-`lance` data viewer, raw
# boto3, the AWS CLI. Lance's Rust object_store reads AWS_ENDPOINT and DuckDB's
# httpfs reads AWS_ENDPOINT_URL; without both, a query over an s3:// .lance
# dataset retries against real AWS S3 and hangs. region=auto is R2's placeholder.
# WARNING: these are GLOBAL AWS SDK overrides — every AWS-SDK call in this shell
# or container is redirected to R2. W&B uses WANDB_S3_ENDPOINT_URL above to avoid
# depending on them; unset these if other code must reach real AWS S3.
AWS_ACCESS_KEY_ID=your-r2-access-key-id
AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key
AWS_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
AWS_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
AWS_REGION=auto

# =============================================================================
# Weights & Biases (experiment tracking)
# =============================================================================
# Used by: training, evaluation, promotion, Docker builds, and the Claude
# Code wandb MCP server wired up by `.mcp.json` (Authorization: Bearer
# ${WANDB_API_KEY} against https://mcp.withwandb.com/mcp).

# W&B API key (from wandb.ai/settings)
WANDB_API_KEY=your-wandb-api-key

# W&B entity and project (both optional — defaults in configs/logger/wandb.yaml).
# Leave WANDB_ENTITY unset to use your W&B account's default entity. Only set
# if you want runs to land under a specific team.
# WANDB_ENTITY=<your-wandb-team>
# WANDB_PROJECT=synth-setter

# Local directory for W&B run data (used by prediction jobs)
# WANDB_DIR=/path/to/wandb/runs

# =============================================================================
# GitHub
# =============================================================================
# Used by: the Claude Code agent inside the dev container to authenticate
# `git` / `gh` operations. Injected via --env-file .env in the devcontainer
# runArgs and consumed by .devcontainer/post-create.sh via `gh auth login`.

# Fine-grained personal access token with scoped repo access
RESTRICTED_AGENT_GIT_PAT=fine-grained-access-token

# =============================================================================
# RunPod (GPU cloud compute) — planned, not yet used in code
# =============================================================================
# Listed here for completeness; the RunPod backend is planned (#71) but not yet
# implemented. No code paths currently read this variable.

# RunPod API key (from runpod.io dashboard)
# RUNPOD_API_KEY=your-runpod-api-key

# =============================================================================
# Docker Hub (container registry)
# =============================================================================
# Used by: CI workflows for image push/pull authentication

DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_TOKEN=your-dockerhub-access-token

# =============================================================================
# Docker build overrides (optional — defaults defined in Makefile)
# =============================================================================

# DOCKER_FILE=docker/ubuntu22_04/Dockerfile
# DOCKER_IMAGE=synth-setter
# DOCKER_BUILD_MODE=prebuilt
# DOCKER_TARGETPLATFORM=linux/amd64
# DOCKER_TORCH_IDX=https://download.pytorch.org/whl/cu128
# DOCKER_BUILD_FLAGS=

# =============================================================================
# Optional: alternative loggers (template-provided, not actively used)
# =============================================================================
# These configs ship with the lightning-hydra-template. The project uses W&B
# (above). Only set these if you switch to an alternative logger config.

# Comet ML (configs/logger/comet.yaml)
# COMET_API_TOKEN=your-comet-api-token

# Neptune AI (configs/logger/neptune.yaml)
# NEPTUNE_API_TOKEN=your-neptune-api-token

# =============================================================================
# Paths
# =============================================================================
# PROJECT_ROOT is published by ``synth_setter.workspace.operator_workspace()``
# at launcher import — resolution order ``$SYNTH_SETTER_WORKSPACE`` >
# checkout root > ``Path.cwd()``. Override the workspace via
# $SYNTH_SETTER_WORKSPACE; a pre-set $PROJECT_ROOT is also respected.

# =============================================================================
# Pipeline / container runtime (set inside Docker containers)
# =============================================================================

# Container dispatch happens via direct invocation of console scripts
# (`synth-setter-generate-dataset`, etc.) inside the image — not an env var.

# Docker image tag — captured by log_wandb_provenance() for experiment tracking
# IMAGE_TAG=dev-snapshot-abc1234

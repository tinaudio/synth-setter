# example of file for storing private and user specific environment variables, like keys or system paths
# rename it to ".env" (excluded from version control by default)
# .env is loaded by train.py automatically
# hydra allows you to reference variables in .yaml configs with special syntax: ${oc.env:MY_VAR}

MY_VAR="/home/user/my/system/path"

# =============================================================================
# Cloudflare R2 credentials — used when building Docker images that bake in
# cloud storage access for dataset generation and upload.
#
# ⚠️  SECURITY: These credentials are baked into the Docker image at build time
#     (via BuildKit --secret, so they do NOT appear in image layers or
#     `docker history`). However, the rclone config they produce IS stored
#     inside the image filesystem.
#
#     → Keep ALL produced Docker images in a PRIVATE registry.
#     → Anyone who can pull the image has read/write access to R2_BUCKET.
#     → Rotate these tokens after each build campaign — they cannot be
#       revoked per-image once baked in.
#
# How to get these values:
#   1. Go to the Cloudflare dashboard → R2 → Manage R2 API Tokens
#   2. Create a token with "Object Read & Write" for your bucket only
#   3. Copy the Access Key ID and Secret Access Key below
#   4. The endpoint URL is: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# =============================================================================
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_BUCKET="your-bucket-name"

{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "pr-reviewer": {
      "description": "Read-only PR review pass for the repo-review-full fan-out",
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "task": "deny",
        "bash": {
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git status*": "allow",
          "gh pr view*": "allow",
          "gh pr diff*": "allow",
          "rg*": "allow",
          "grep*": "allow",
          "cat*": "allow",
          "ls*": "allow",
          "sed -n*": "allow",
          "*": "deny"
        }
      }
    }
  }
}
